MODE=asft
USE_ADAPTER=true
ADAPTER_TYPE=oftv2
TARGET_MODULES=q_proj,v_proj
ADAPTER_BIAS=none

LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05

OFT_BLOCK_SIZE=32
OFT_R=0
OFT_MODULE_DROPOUT=0.0
USE_CAYLEY_NEUMANN=true

USE_OFT_REGULARIZER=true
LAMBDA_OFT=0.5
OFT_REGULARIZER_TYPE=identity

MODEL_MAX_LENGTH=512
PER_DEVICE_TRAIN_BATCH_SIZE=4
GLOBAL_BATCH_SIZE=64
NUM_TRAIN_EPOCHS=3
LEARNING_RATE=5e-4
