MODE=asft
USE_ADAPTER=true
ADAPTER_TYPE=oftv2
TARGET_MODULES=q_proj,v_proj
ADAPTER_BIAS=none

OFT_BLOCK_SIZE=8
OFT_R=0
OFT_MODULE_DROPOUT=0.0
USE_CAYLEY_NEUMANN=true

USE_OFT_REGULARIZER=true
LAMBDA_OFT=0.5
OFT_REGULARIZER_TYPE=identity

PER_DEVICE_TRAIN_BATCH_SIZE=1
GLOBAL_BATCH_SIZE=1
NUM_TRAIN_EPOCHS=1
LEARNING_RATE=1e-4
